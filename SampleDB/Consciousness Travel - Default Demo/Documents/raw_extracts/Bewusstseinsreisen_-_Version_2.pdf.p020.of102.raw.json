          "page": 20,
          "paragraph_index": 19
        }
      },
      {
        "id": "page20_para_20",
        "type": "paragraph",
        "value": "Es bedurfte noch deutlich mehr, vielleicht an die hundert solcher Begegnungen um",
        "position": {
          "page": 20,
          "paragraph_index": 20
        }
      },
      {
        "id": "page20_para_21",

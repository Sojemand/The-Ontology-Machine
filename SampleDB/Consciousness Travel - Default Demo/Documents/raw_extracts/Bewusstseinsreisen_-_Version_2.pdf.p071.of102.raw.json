          "paragraph_index": 1
        }
      },
      {
        "id": "page71_para_2",
        "type": "paragraph",
        "value": "erwecken, sie hätten irgendeine belastbare Basis in der Wirklichkeit, so täuscht uns dieses",
        "position": {

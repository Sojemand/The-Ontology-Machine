  "contract_module": "validator_vision.orchestrator_contract",
  "edit_contract_module": "validator_vision.edit_contract",
  "actions": ["validate_document", "healthcheck", "debug_run"],
  "edit_surfaces": ["validator.settings", "validator.report_preview_policy", "validator.debug_capabilities"],
